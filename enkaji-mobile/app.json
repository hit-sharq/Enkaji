{
  "expo": {
    "name": "Enkaji",
    "slug": "enkaji-mobile",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/favicon.png",
    "scheme": "enkaji",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/favicon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.enkaji.mobile",
      "permissions": ["ACCESS_FINE_LOCATION"],
      "versionCode": 4,
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "https",
              "host": "enkaji.vercel.app",
              "pathPrefix": "/"
            },
            {
              "scheme": "https",
              "host": "www.enkaji.vercel.app",
              "pathPrefix": "/"
            },
            {
              "scheme": "enkaji"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.enkaji.mobile",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "Enkaji needs your location to auto-fill your shipping address for faster checkout.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Enkaji needs your location to auto-fill your shipping address for faster checkout."
      },
      "buildNumber": "4",
      "associatedDomains": [
        "applinks:enkaji.vercel.app",
        "applinks:www.enkaji.vercel.app"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "server",
      "favicon": "./assets/favicon.png",
      "notification": {
        "vapidPublicKey": "BMKXz6dJ6J5pZ5q5p5q5p5q5p5q5p5q5p5q5p5q5p5q5p5q5p5q5p5q5p5q5p5q5p5q5p5q5p5q5p5q5p5q5p5q5p5q5p5q5p5q5p5q5p5q5p5q5p5q5p5q5p5q5p5q5p"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "85373eeb-84ea-4aca-9871-888b06f295d5"
      }
    },
    "owner": "hit-sharq",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/85373eeb-84ea-4aca-9871-888b06f295d5"
    }
  }
}
